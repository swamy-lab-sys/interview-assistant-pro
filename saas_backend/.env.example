# Interview Assistant Pro - Environment Variables

# Database (auto-set by Render)
DATABASE_URL=sqlite+aiosqlite:///./interview_assistant.db

# Security
SECRET_KEY=change-this-to-random-string

# Anthropic API (YOUR master key - users don't need their own)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx

# Stripe (for payments)
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_PRICE_ID_MONTHLY=price_xxxxx

# Usage Limits
FREE_TIER_QUESTIONS_PER_MONTH=50
PRO_TIER_QUESTIONS_PER_MONTH=10000
