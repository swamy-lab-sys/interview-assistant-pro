# Interview Voice Assistant - Environment Variables
# Copy this file to .env and fill in your values

# REQUIRED: Anthropic Claude API Key
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# OPTIONAL: Hugging Face Token (for advanced speaker diarization)
# Get from: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=

# OPTIONAL: Speaker volume threshold (auto-calibrated by default)
# Adjust if speaker detection is too sensitive/insensitive
SPEAKER_VOLUME_THRESHOLD=

# OPTIONAL: PulseAudio source (auto-configured by run.sh)
# Use 'pactl list short sources' to find available sources
# Example: alsa_output.pci-0000_00_1f.3.analog-stereo.monitor
PULSE_SOURCE=
